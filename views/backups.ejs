<!DOCTYPE html>
<html>

<head>
    <title>Backups</title>

    <style>
        body {
            font-family: Arial;
            background: #f5f6fa;
            padding: 40px;
        }

        /* DATE CONTAINER */

        .date-section {
            margin-bottom: 20px;
            background: white;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
        }

        /* HEADER BAR */

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 18px;
            background: #2f3640;
            color: white;
            cursor: pointer;
        }

        .header h2 {
            font-size: 16px;
            margin: 0;
        }

        .arrow {
            margin-right: 10px;
            transition: transform 0.2s;
        }

        /* TABLE */

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th,
        td {
            padding: 10px;
            border-bottom: 1px solid #eee;
        }

        th {
            background: #f3f4f6;
            text-align: left;
        }

        /* BUTTONS */

        .download {
            background: #27ae60;
            color: white;
            padding: 6px 10px;
            text-decoration: none;
            border-radius: 4px;
            font-size: 13px;
        }

        .download-all {
            background: #2980b9;
            color: white;
            padding: 6px 12px;
            text-decoration: none;
            border-radius: 4px;
            font-size: 13px;
        }

        /* COLLAPSIBLE CONTENT */

        .content {
            display: none;
        }

        .date-section.active .content {
            display: block;
        }

        .date-section.active .arrow {
            transform: rotate(90deg);
        }
    </style>
</head>

<body>

    <h1>Database Backups</h1>

    <% Object.keys(backups).forEach((date, index)=> { %>

        <div class="date-section <%= index === 0 ? 'active' : '' %>">

            <div class="header">

                <div style="display:flex;align-items:center;gap:10px;">
                    <span class="arrow">▶</span>
                    <h2>
                        <%= date %>
                    </h2>
                </div>

                <a class="download-all" href="/api/backups/download-date/<%= date %>" onclick="event.stopPropagation()">
                    Download All
                </a>

            </div>

            <div class="content">

                <table>

                    <thead>
                        <tr>
                            <th>Database</th>
                            <th>File</th>
                            <th>Size MB</th>
                            <th>Download</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% backups[date].forEach(b=> { %>

                            <tr>
                                <td>
                                    <%= b.database %>
                                </td>
                                <td>
                                    <%= b.file %>
                                </td>
                                <td>
                                    <%= b.size %>
                                </td>

                                <td>
                                    <a class="download" href="<%= b.url %>">
                                        Download
                                    </a>
                                </td>

                            </tr>

                            <% }) %>

                    </tbody>

                </table>

            </div>

        </div>

        <% }) %>

            <script>

                document.querySelectorAll(".header").forEach(header => {

                    header.addEventListener("click", () => {

                        const section = header.parentElement;

                        section.classList.toggle("active");

                    });

                });

            </script>

</body>

</html>